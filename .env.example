# Database
DATABASE_URL=postgresql://localhost:5432/agent_hive

# API / Dashboard
AGENT_HIVE_API_URL=http://localhost:3000
AGENT_HIVE_API_KEY=your_api_key_here
AGENT_HIVE_INTERNAL_KEY=your_internal_key_here

# Enricher Feature Flags (all default to true)
ENABLE_DEMAND_DETECTION=true
ENABLE_CO_OCCURRENCE=true
ENABLE_FRESHNESS=true
ENABLE_TRUST_CASCADE=true
ENABLE_DOMAIN_EXPERTISE=true
